{
  "$schema": "https://go.kicad.org/api/schemas/v1",
  "identifier": "com.github.tobiglaser.KiPEX",
  "name": "KiPEX",
  "description": "",
  "runtime": {
    "type": "python",
    "min_version": "3.10"
  },
  "actions": [
    {
      "identifier": "KiPEX",
      "name": "Open KiPEX",
      "description": "",
      "show-button": true,
      "scopes": [
          "pcb"
      ],
      "entrypoint": "main.py",
      "icons-light": [
        "icons/icon.png"
      ]
    },
    {
      "identifier": "Translator",
      "name": "Translator",
      "description": "Run translator.py directly",
      "show-button": true,
      "scopes": [
          "pcb"
      ],
      "entrypoint": "translator.py",
      "icons-light": [
        "icons/icon_green.png"
      ]
    }
  ]
}
